# Zuri Market — Terraform variable values (template)
# Copy this file to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored.

# Your public IP in CIDR form (suffix /32 = single IP).
# Find yours: https://api.ipify.org
home_ip_cidr = "81.2.3.4/32"

# Your SSH public key. Generate with: ssh-keygen -t ed25519 -C "you@example.com"
# Then paste the contents of ~/.ssh/id_ed25519.pub here.
ssh_public_key = "ssh-ed25519 AAAA...your-key-here... you@example.com"