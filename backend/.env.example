# Zuri Market backend — environment variables template
# Copy this file to .env and fill in the values for local development.
# In production these values come from AWS Secrets Manager.

# Server config
PORT=4000

# Store config — STORE_NAME comes from AWS Secrets Manager in production
STORE_NAME=Zuri Market
CURRENCY=GBP

# Security — API_SECRET_KEY comes from AWS Secrets Manager in production
# Generate locally with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=replace-with-your-local-dev-secret

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173